{
  "uid": "quicknotes-golden",
  "title": "QuickNotes — Four Golden Signals",
  "tags": ["quicknotes", "sre"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency — scrape duration (proxy; app exposes no histogram)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scrape_duration_seconds{job=\"quicknotes\"}",
          "legendFormat": "scrape duration"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Traffic — HTTP requests per second",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quicknotes_http_requests_total[1m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Errors — error ratio (5xx and non-2xx)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quicknotes_http_responses_by_code_total{code=~\"5..\"}[5m])) / clamp_min(sum(rate(quicknotes_http_requests_total[5m])), 0.001)",
          "legendFormat": "5xx ratio"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quicknotes_http_responses_by_code_total{code=~\"4..|5..\"}[5m])) / clamp_min(sum(rate(quicknotes_http_requests_total[5m])), 0.001)",
          "legendFormat": "non-2xx ratio"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Saturation — notes stored (storage proxy)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quicknotes_notes_total",
          "legendFormat": "notes stored"
        }
      ]
    }
  ]
}
